package tpintegrador_programacion2.config;

import java.util.ArrayList;
import entities.Usuario;
import enums.Rol;
import java.util.Scanner;

public class CRUDUsuarios {
    ArrayList<Usuario> usuarios = new ArrayList<>();
    public ArrayList<Usuario> getUsuarios() { // PERMITE QUE PEDIDOS ACCEDA A LA LISTA DE USUARIOS
        return usuarios;
    }
    public void menuUsuarios(Scanner input) {

        int opcion = -1;
        do {
            System.out.println("\n--- USUARIOS ---");
            System.out.println("1. Listar");
            System.out.println("2. Crear");
            System.out.println("3. Editar");
            System.out.println("4. Eliminar");
            System.out.println("0. Volver");

            opcion = Integer.parseInt(input.nextLine());

            switch (opcion) {
                case 1:// listar
                    boolean hayUsuarios = false;
                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(u);
                            hayUsuarios = true;
                        }
                    }
                    if (!hayUsuarios) {
                        System.out.println("No hay usuarios cargados");
                    }
                    break;

                case 2:
                    // crear
                    System.out.print("Nombre: ");
                    String nombre = input.nextLine();

                    System.out.print("Apellido: ");
                    String apellido = input.nextLine();

                    System.out.print("Mail: ");
                    String mail = input.nextLine();

                    System.out.println("Rol:");
                    System.out.println("1. ADMIN");
                    System.out.println("2. USUARIO");

                    int opcionRol
                            = Integer.parseInt(input.nextLine());

                    Rol rol;

                    if (opcionRol == 1) {
                        rol = Rol.ADMIN;
                    } else {
                        rol = Rol.USUARIO;
                    }
                    Usuario usuario
                            = new Usuario(
                                    nombre,
                                    apellido,
                                    mail,
                                    rol);
                    usuarios.add(usuario);

                    System.out.println("Usuario creado");
                    break;

                case 3:
                    // editar
                    System.out.println("\nUsuarios disponibles:");

                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + u.getId()
                                    + " - "
                                    + u.getNombre());
                        }
                    }
                    System.out.print("Ingrese id del usuario a editar: ");
                    Long idEditar
                            = Long.parseLong(input.nextLine());
                    Usuario usuarioEditar = null;

                    for (Usuario u : usuarios) {
                        if (u.getId().equals(idEditar)
                                && !u.isEliminado()) {
                            usuarioEditar = u;
                            break;
                        }
                    }
                    if (usuarioEditar == null) {
                        System.out.println("Usuario no encontrado");
                        break;
                    }
                    System.out.print("Nuevo nombre: ");
                    usuarioEditar.setNombre(input.nextLine());

                    System.out.print("Nuevo apellido: ");
                    usuarioEditar.setApellido(input.nextLine());

                    System.out.print("Nuevo mail: ");
                    usuarioEditar.setMail(input.nextLine());

                    System.out.println("Usuario editado");
                    
                    break;

                case 4:
                    // eliminar
                    System.out.println("\nUsuarios disponibles:");
                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + u.getId()
                                    + " - "
                                    + u.getNombre());
                        }
                    }

                    System.out.print("Ingrese id del usuario que desea eliminar: ");

                    Long idEliminar = Long.parseLong(input.nextLine());
                    Usuario usuarioEliminar = null;

                    for (Usuario u : usuarios) {
                        if (u.getId().equals(idEliminar)
                                && !u.isEliminado()) {
                            usuarioEliminar = u;
                            break;
                        }
                    }

                    if (usuarioEliminar == null) {
                        System.out.println(
                                "Usuario no encontrado");
                    } else {
                        usuarioEliminar.setEliminado(true);
                        System.out.println(
                                "Usuario eliminado correctamente");
                    }
                    break;

                case 0:
                    System.out.println("Volviendo al menu principal");
                    break;
            }

        } while (opcion != 0);
    }
    
    
}

