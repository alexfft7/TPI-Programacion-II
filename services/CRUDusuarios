package tpintegrador_programacion2.config;

import java.util.ArrayList;
import entities.Usuario;
import enums.Rol;
import java.util.Scanner;

public class CRUDUsuarios {
    ArrayList<Usuario> usuarios = new ArrayList<>();
    public ArrayList<Usuario> getUsuarios() { // PERMITE QUE PEDIDOS ACCEDA A LA LISTA DE USUARIOS
        return usuarios;
    }
    public void menuUsuarios(Scanner input) {

        int opcion = -1;
        do {
            System.out.println("\n--- USUARIOS ---");
            System.out.println("1. Listar");
            System.out.println("2. Crear");
            System.out.println("3. Editar");
            System.out.println("4. Eliminar");
            System.out.println("0. Volver");

            try {
            opcion = Integer.parseInt(input.nextLine());
            } catch (NumberFormatException e) {
                System.out.println("Error: debe ingresar una opción válida.");
                continue;
            }

            switch (opcion) {
                case 1:// listar
                    boolean hayUsuarios = false;
                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(u);
                            hayUsuarios = true;
                        }
                    }
                    if (!hayUsuarios) {
                        System.out.println("No hay usuarios cargados");
                    }
                    break;

                case 2:
                    // crear
                    System.out.print("Nombre: ");
                    String nombre = input.nextLine();

                    System.out.print("Apellido: ");
                    String apellido = input.nextLine();

                    System.out.print("Mail: ");
                    String mail = input.nextLine();

                    if (mail.isEmpty()) {
                        System.out.println("Error: el mail no puede estar vacío.");
                        break;
                    }

                    boolean mailExiste = false;

                    for (Usuario u : usuarios) {
                        if (!u.isEliminado() && u.getMail().equalsIgnoreCase(mail)) {

                            mailExiste = true;
                            break;
                        }
                    }

                    if (mailExiste) {
                        System.out.println("Error: el mail ya existe.");
                        break;
                    }

                    System.out.print("Celular: ");
                    String celular = input.nextLine();

                    System.out.println("Rol:");
                    System.out.println("1. ADMIN");
                    System.out.println("2. USUARIO");

                    int opcionRol;
                     try {
                        opcionRol = Integer.parseInt(input.nextLine());
                    } catch (NumberFormatException e) {
                        System.out.println("Error: rol inválido.");
                        break;
                    }       

                    Rol rol;

                    if (opcionRol == 1) {
                        rol = Rol.ADMIN;
                    } else {
                        rol = Rol.USUARIO;
                    }
                    Usuario usuario
                            = new Usuario(
                                    nombre,
                                    apellido,
                                    mail,
                                    celular,
                                    rol);
                    usuarios.add(usuario);

                    System.out.println("Usuario creado con ID: " + usuario.getId());
                    break;

                case 3:
                    // editar
                    System.out.println("\nUsuarios disponibles:");

                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + u.getId()
                                    + " - "
                                    + u.getNombre());
                        }
                    }
                    System.out.print("Ingrese id del usuario a editar: ");
                    Long idEditar;
                    try {
                        idEditar = Long.parseLong(
                                input.nextLine());
                    } catch (NumberFormatException e) {
                        System.out.println("ID inválido.");
                        break;
                    }

                    Usuario usuarioEditar = null;

                    for (Usuario u : usuarios) {
                        if (u.getId().equals(idEditar)
                                && !u.isEliminado()) {
                            usuarioEditar = u;
                            break;
                        }
                    }
                    if (usuarioEditar == null) {
                        System.out.println("Usuario no encontrado");
                        break;
                    }
                    System.out.print("Nuevo nombre: ");
                    usuarioEditar.setNombre(input.nextLine());

                    System.out.print("Nuevo apellido: ");
                    usuarioEditar.setApellido(input.nextLine());

                    System.out.print("Nuevo mail: ");
                    String nuevoMail =
                            input.nextLine().trim();

                    boolean mailDuplicado = false;

                    for (Usuario u : usuarios) {

                        if (!u.getId().equals(
                                usuarioEditar.getId())
                                && !u.isEliminado()
                                && u.getMail()
                                        .equalsIgnoreCase(
                                                nuevoMail)) {

                            mailDuplicado = true;
                            break;
                        }
                    }

                    if (mailDuplicado) {
                        System.out.println("Error: el mail ya existe.");

                        break;
                    }

                    usuarioEditar.setMail(nuevoMail);

                    System.out.print("Nuevo celular: ");
                    usuarioEditar.setCelular(input.nextLine());

                    System.out.print(
                            "¿Confirma la actualización? (S/N): ");

                    String confirmarEdicion =
                            input.nextLine();

                    if (confirmarEdicion
                            .equalsIgnoreCase("S")) {

                        System.out.println(
                                "Usuario editado correctamente");

                    } else {

                        System.out.println(
                                "Actualización cancelada");
                    }

                    break;

                case 4:
                    // eliminar
                    System.out.println("\nUsuarios disponibles:");
                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + u.getId()
                                    + " - "
                                    + u.getNombre());
                        }
                    }

                    System.out.print("Ingrese id del usuario que desea eliminar: ");

                    Long idEliminar;
                    try {
                        idEliminar = Long.parseLong(
                                input.nextLine());
                    } catch (NumberFormatException e) {
                        System.out.println(
                                "ID inválido.");
                        break;
                    }

                    Usuario usuarioEliminar = null;

                    for (Usuario u : usuarios) {
                        if (u.getId().equals(idEliminar)
                                && !u.isEliminado()) {
                            usuarioEliminar = u;
                            break;
                        }
                    }

                    if (usuarioEliminar == null) {
                        System.out.println(
                                "Usuario no encontrado");
                    } else {
                        System.out.print("¿Confirma la eliminación? (S/N): ");

                        String confirmacion = input.nextLine();

                        if (confirmacion.equalsIgnoreCase("S")) {

                            usuarioEliminar.setEliminado(true);
                            System.out.println("Usuario eliminado correctamente");

                        } else {
                            System.out.println("Eliminación cancelada");
                        }
                    }
                    break;

                case 0:
                    System.out.println("Volviendo al menu principal");
                    break;
            }

        } while (opcion != 0);
    }
    
    
}

