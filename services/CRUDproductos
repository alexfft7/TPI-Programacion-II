package tpintegrador_programacion2.services;

import entities.Categoria;
import java.util.ArrayList;
import java.util.Scanner;
import entities.Producto;

public class CRUDProductos {
    ArrayList<Producto> productos = new ArrayList<>();
    private ArrayList<Categoria> categorias;

    public CRUDProductos(ArrayList<Categoria> categorias) {
        this.categorias = categorias;
    }
    public ArrayList<Producto> getProductos() {
        return productos;
    }
    public void menuProductos(Scanner input){
        int opcion = -1;

        do{

            System.out.println("\n--- PRODUCTOS ---");
            System.out.println("1. Listar");
            System.out.println("2. Crear");
            System.out.println("3. Editar");
            System.out.println("4. Eliminar");
            System.out.println("0. Volver");

            try {
            opcion = Integer.parseInt(input.nextLine());
            } catch (NumberFormatException e) {
                System.out.println("Error: debe ingresar una opción numérica.");
                continue;
            }

            switch(opcion){
                case 1:// Listar 
                    boolean hayProductos = false;
  
                    for (Producto p : productos) {
                        if (!p.isEliminado()) {
                            System.out.println(
                                    "ID: " + p.getId()
                                    + " | Nombre: " + p.getNombre()
                                    + " | Precio: " + p.getPrecio()
                                    + " | Stock: " + p.getStock()
                                    + " | Categoria: "
                                    + p.getCategoria().getNombre()
                            );
                            hayProductos = true;
                        }
                    }
                    if (!hayProductos) {
                        System.out.println("No hay productos cargados");
                    }
                    break;
                case 2: // Crear
                    System.out.println("Categorias disponibles:");
                    for (Categoria c : categorias) {
                        if (!c.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + c.getId()
                                    + " - "
                                    + c.getNombre());
                        }
                    }
                    System.out.print("Ingrese id de la categoria: ");
                    Long idCategoria
                            = Long.parseLong(input.nextLine());
                    Categoria categoriaSeleccionada = null;

                    for (Categoria c : categorias) {
                        if (c.getId().equals(idCategoria)
                                && !c.isEliminado()) {
                            categoriaSeleccionada = c;
                            break;
                        }
                    }
                    if (categoriaSeleccionada == null) {
                        System.out.println("Categoria no encontrada");
                        break;
                    }
                    System.out.print("Nombre: ");
                    String nombre = input.nextLine();
                    if (nombre.isEmpty()) {  
                        throw new IllegalArgumentException(
                            "El nombre no puede estar vacío.");
                        }

                    System.out.print("Precio: ");
                    double precio = Double.parseDouble(input.nextLine());
                    if (precio < 0) {  
                        throw new IllegalArgumentException(
                            "El precio no puede ser negativo.");
                        }

                    System.out.print("Stock: ");
                    int stock = Integer.parseInt(input.nextLine());
                    if (stock < 0) {
                        throw new IllegalArgumentException(
                            "El stock no puede ser negativo.");
                        }

                    System.out.print("Disponible:  (true/false)");
                    boolean disponible = Boolean.parseBoolean(input.nextLine());

                    Producto producto = new Producto(
                            nombre,
                            precio,
                            stock,
                            disponible
                            categoriaSeleccionada
                    );
                    
                    categoriaSeleccionada.agregarProducto(producto);

                    productos.add(producto);

                    System.out.println("Producto creado con ID: " + producto.getId());
                    } catch (NumberFormatException e) {

                        System.out.println(
                                "Error: formato numérico inválido.");

                    } catch (IllegalArgumentException e) {

                        System.out.println(
                                "Error: " + e.getMessage());
                    }
                    break;
                            
                case 3:// Editar
                    System.out.println("\nProductos disponibles:");
                    for (Producto p : productos) {
                    if (!p.isEliminado()) {
                        System.out.println( 
                                "ID: " + p.getId() + " - " + p.getNombre());}
                    }
                    try {
                    System.out.print("Ingrese id del producto que desea editar: ");
                    Long idEditar = Long.parseLong (input.nextLine());
                    
                    Producto productoEditar = null;
                    
                    for (Producto p : productos) {
                        if (p.getId().equals(idEditar) && !p.isEliminado()) {
                            productoEditar = p;
                            
                            break;
                        }
                    }
                    if (productoEditar == null) {
                        System.out.println("Producto no encontrado");
                        break;
                    }
                    System.out.print("Nuevo nombre (ENTER para mantener): "); //ACTUALIZACIONES PARCIALES
                    String nuevoNombre = input.nextLine();
                        if (!nuevoNombre.isBlank()) {
                            productoEditar.setNombre(nuevoNombre);
                        }

                    System.out.print("Nuevo precio (ENTER para mantener): ");
                    String precioTexto = input.nextLine();
                        if (!precioTexto.isBlank()) {
                            double nuevoPrecio = Double.parseDouble(precioTexto);
                            if (nuevoPrecio < 0) {
                                throw new IllegalArgumentException("El precio no puede ser negativo.");
                            }
                            productoEditar.setPrecio(nuevoPrecio);
                        }

                    System.out.print("Nuevo stock (ENTER para mantener): ");
                        String stockTexto = input.nextLine();
                        if (!stockTexto.isBlank()) {
                            int nuevoStock = Integer.parseInt(stockTexto); 
                            if (nuevoStock < 0) {
                                throw new IllegalArgumentException("El stock no puede ser negativo.");
                            }
                            productoEditar.setStock(nuevoStock);
                        } 

                    System.out.println("Producto editado");
                    } catch (NumberFormatException e) { //CATCH

                        System.out.println(
                                "Error: valor numérico inválido.");

                    } catch (IllegalArgumentException e) {

                        System.out.println(
                                "Error: " + e.getMessage());
                    }
                    break;
                
                case 4:
                    try {
                    System.out.print("Ingrese id del producto a eliminar: ");
                    Long idEliminar = Long.parseLong(input.nextLine());
                    Producto productoEliminar = null;
                    for (Producto p : productos) {
                        if (p.getId().equals(idEliminar) && !p.isEliminado()) {
                            productoEliminar = p;
                            break;
                        }
                    }

                    if (productoEliminar == null) {
                        System.out.println("Producto no encontrado");
                    } else {
                        System.out.print("¿Confirma la eliminación? (S/N): "); //CONFIRMAR ELIMINAR
                            String confirmacion = input.nextLine();

                            if (confirmacion.equalsIgnoreCase("S")) {
                                productoEliminar.setEliminado(true);

                                System.out.println("Producto eliminado correctamente");

                            } else {
                                System.out.println("Eliminación cancelada");
                            }
                        }
                    } catch (NumberFormatException e) {

                        System.out.println(
                                "Error: ID inválido.");
                    }

                    break;

                case 0:
                    System.out.println("Volviendo al menu principal");
                    break;
            }

        } while (opcion != 0);
    }
}
