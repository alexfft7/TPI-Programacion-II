package tpintegrador_programacion2.Main;

import java.util.ArrayList;
import java.util.Scanner;
import entities.Pedido;
import entities.Producto;
import entities.Usuario;
import enums.Estado;
import enums.FormaPago;

public class CRUDPedidos {

    ArrayList<Pedido> pedidos = new ArrayList<>();
    private ArrayList<Usuario> usuarios;
    private ArrayList<Producto> productos;

    public CRUDPedidos(
            ArrayList<Usuario> usuarios,
            ArrayList<Producto> productos) {

        this.usuarios = usuarios;
        this.productos = productos;
    }

    public void menuPedidos(Scanner input) {

        int opcion = -1;

        do {

            System.out.println("\n--- PEDIDOS ---");
            System.out.println("1. Listar");
            System.out.println("2. Crear");
            System.out.println("3. Editar");
            System.out.println("4. Eliminar");
            System.out.println("0. Volver");

            try {
                opcion = Integer.parseInt(input.nextLine());
            } catch (NumberFormatException e) {
                System.out.println("Debe ingresar una opción válida.");
                continue;
            }

            switch (opcion) {
                case 1:
                    // Listar
                    boolean hayPedidos = false;
                    for (Pedido p : pedidos) {
                        if (!p.isEliminado()) {
                            System.out.println(p);
                            hayPedidos = true;
                        }
                    }
                    if (!hayPedidos) {
                        System.out.println("No hay pedidos cargados");
                    }

                    break;

                case 2:
                    // Crear
                    System.out.println("\nUsuarios disponibles:");
                    for (Usuario u : usuarios) {
                        if (!u.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + u.getId()
                                    + " - "
                                    + u.getNombre());
                        }
                    }

                    Long idUsuario;

                    try {
                        System.out.print("Ingrese id del usuario: ");
                        idUsuario = Long.parseLong(input.nextLine());

                    } catch (NumberFormatException e) {
                        System.out.println( "ID inválido.");

                        break;
                    }

                    Usuario usuarioSeleccionado = null;

                    for (Usuario u : usuarios) {
                        if (u.getId().equals(idUsuario)
                                && !u.isEliminado()) {

                            usuarioSeleccionado = u;
                            break;
                        }
                    }

                    if (usuarioSeleccionado == null) {
                        System.out.println("Usuario no encontrado");
                        break;
                    }

                    System.out.println("Estado:");
                    System.out.println("1. PENDIENTE");
                    System.out.println("2. CONFIRMADO");
                    System.out.println("3. TERMINADO");
                    System.out.println("4. CANCELADO");

                    int opcionEstado;
                    try {
                        opcionEstado = Integer.parseInt(input.nextLine());

                    } catch (NumberFormatException e) {
                        System.out.println("Estado inválido");

                        break;
                    } 

                    Estado estado;

                    switch (opcionEstado) {
                        case 2:
                            estado = Estado.CONFIRMADO;
                            break;

                        case 3:
                            estado = Estado.TERMINADO;
                            break;

                        case 4:
                            estado = Estado.CANCELADO;
                            break;

                        default:
                            estado = Estado.PENDIENTE;
                    }

                    System.out.println("Forma de Pago:");
                    System.out.println("1. TARJETA");
                    System.out.println("2. TRANSFERENCIA");
                    System.out.println("3. EFECTIVO");

                    int opcionPago;

                    try {
                        opcionPago = Integer.parseInt(input.nextLine());

                    } catch (NumberFormatException e) {
                        System.out.println("Forma de pago inválida");

                        break;
                    }

                    FormaPago formaPago;

                    switch (opcionPago) {
                        case 2:
                            formaPago = FormaPago.TRANSFERENCIA;
                            break;

                        case 3:
                            formaPago = FormaPago.EFECTIVO;
                            break;

                        default:
                            formaPago = FormaPago.TARJETA;
                    }

                    Pedido pedido = new Pedido(estado, formaPago);

                    String continuar;
                    do {
                    System.out.println("\nProductos disponibles:");

                    for (Producto p : productos) {
                        if (!p.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + p.getId()
                                    + " - "
                                    + p.getNombre()
                                    + " ($"
                                    + p.getPrecio()
                                    + ")");
                        }
                    }
                    Long idProducto;
                        try {
                    System.out.print("Ingrese id del producto: ");
                    idProducto
                            = Long.parseLong(input.nextLine());
                    } catch (NumberFormatException e) {
                            System.out.println("ID inválido.");

                            break;
                    }

                    Producto productoSeleccionado = null;

                    for (Producto p : productos) {
                        if (p.getId().equals(idProducto)
                                && !p.isEliminado()) {

                            productoSeleccionado = p;
                            break;
                        }
                    }

                    if (productoSeleccionado == null) {
                        System.out.println("Producto no encontrado");
                        break;
                    }

                    int cantidad;
                    try {
                    System.out.print("Cantidad: ");
                    cantidad
                            = Integer.parseInt(input.nextLine());
                    } catch (NumberFormatException e) {
                            System.out.println("Cantidad inválida");

                            break;
                        }

                    try {
                    pedido.addDetallePedido(
                            cantidad,
                            productoSeleccionado);
                    } catch (Exception e) {
                            System.out.println("Error al agregar detalle: " + e.getMessage());
                            pedido = null;

                            break;
                        }

                        System.out.print("¿Agregar otro producto? (S/N): ");

                        continuar =input.nextLine();

                    } while (continuar.equalsIgnoreCase("S"));

                    if (pedido == null) {
                        System.out.println("Pedido cancelado.");

                        break;
                    }

                    usuarioSeleccionado.agregarPedido(pedido);

                    pedidos.add(pedido);

                    System.out.println(
                            "Pedido creado. Total: $"
                            + pedido.getTotal());

                    break;

                case 3:
                    // Editar
                    System.out.println("\nPedidos disponibles:");
                    for (Pedido p : pedidos) {
                        if (!p.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + p.getId()
                                    + " - "
                                    + p.getEstado());
                        }
                    }
                    Long idEditar;

                    try {
                        System.out.print("Ingrese id del pedido a editar: ");
                        idEditar =
                                Long.parseLong(input.nextLine());

                    } catch (NumberFormatException e) {
                        System.out.println("ID inválido.");

                        break;
                    }

                    Pedido pedidoEditar = null;

                    for (Pedido p : pedidos) {
                        if (p.getId().equals(idEditar)
                                && !p.isEliminado()) {

                            pedidoEditar = p;
                            break;
                        }
                    }

                    if (pedidoEditar == null) {
                        System.out.println(
                                "Pedido no encontrado");
                        break;
                    }

                    System.out.println("Nuevo Estado:");
                    System.out.println("1. PENDIENTE");
                    System.out.println("2. CONFIRMADO");
                    System.out.println("3. TERMINADO");
                    System.out.println("4. CANCELADO");

                    int nuevoEstado
                            = Integer.parseInt(input.nextLine());

                    switch (nuevoEstado) {

                        case 2:
                            pedidoEditar.setEstado(
                                    Estado.CONFIRMADO);
                            break;

                        case 3:
                            pedidoEditar.setEstado(
                                    Estado.TERMINADO);
                            break;

                        case 4:
                            pedidoEditar.setEstado(
                                    Estado.CANCELADO);
                            break;

                        default:
                            pedidoEditar.setEstado(
                                    Estado.PENDIENTE);
                    }

                    System.out.println("Nueva Forma de Pago:");

                    System.out.println( "1. TARJETA");
                    System.out.println("2. TRANSFERENCIA");
                    System.out.println("3. EFECTIVO");

                    int nuevoPago = Integer.parseInt(input.nextLine());

                    switch (nuevoPago) {

                        case 2:
                            pedidoEditar.setFormaPago(
                            FormaPago.TRANSFERENCIA);
                            break;

                        case 3:
                            pedidoEditar.setFormaPago(
                            FormaPago.EFECTIVO);
                            break;

                        default:
                            pedidoEditar.setFormaPago(
                            FormaPago.TARJETA);
                    }

                    System.out.println(
                            "Pedido editado");

                    break;

                case 4:
                    // Eliminar

                    System.out.println("\nPedidos disponibles:");

                    for (Pedido p : pedidos) {
                        if (!p.isEliminado()) {
                            System.out.println(
                                    "ID: "
                                    + p.getId()
                                    + " - "
                                    + p.getEstado());
                        }
                    }

                    Long idEliminar;

                    try {
                        System.out.print("Ingrese id del pedido a eliminar: ");
                        idEliminar = Long.parseLong(input.nextLine());

                    } catch (NumberFormatException e) {
                        System.out.println("ID inválido.");

                        break;
                    }

                    Pedido pedidoEliminar = null;

                    for (Pedido p : pedidos) {
                        if (p.getId().equals(idEliminar)
                                && !p.isEliminado()) {

                            pedidoEliminar = p;
                            break;
                        }
                    }

                    if (pedidoEliminar == null) {

                        System.out.println(
                                "Pedido no encontrado");

                    } else {
                        System.out.print("¿Confirma la eliminación? (S/N): ");

                        String confirmacion = input.nextLine();

                        if (confirmacion.equalsIgnoreCase("S")) {
                            pedidoEliminar.setEliminado(true);

                        System.out.println("Pedido eliminado correctamente");
                    } else {

                            System.out.println(
                                    "Eliminación cancelada");
                        }
                    }

                    break;

                case 0:
                    System.out.println(
                            "Volviendo al menu principal");
                    break;
            }

        } while (opcion != 0);
    }
}
